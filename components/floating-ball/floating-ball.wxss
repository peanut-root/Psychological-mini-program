/* components/floating-ball/floating-ball.wxss */

/* === Floating Ball === */
.floating-ball {
  position: fixed;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  border: 4rpx solid #6BAAF7;
  box-shadow: 0 4rpx 12rpx rgba(107, 170, 247, 0.28);
}

.ball-transition {
  transition: left 0.3s ease-out, top 0.3s ease-out;
}

.ball-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
}

/* === Chat Panel Mask === */
.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 9997;
  opacity: 0;
  transition: opacity 0.3s ease-out;
}

.panel-mask-visible {
  opacity: 1;
  background-color: rgba(0, 0, 0, 0.3);
}

/* === Chat Panel Container === */
.panel-container {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
  background-color: #FFFFFF;
  box-shadow: -4rpx 0 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.4s ease-out;
  border-radius: 32rpx 0 0 32rpx;
  overflow: hidden;
}

.panel-slide-in {
  transform: translateX(0);
}

/* === Panel Header === */
.panel-header {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 130rpx;
  padding: 56rpx 32rpx 20rpx;
  background-color: #FFF6D8;
  border-bottom: 1rpx solid #F0E6C0;
  flex-shrink: 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* === Message Area === */
.panel-messages {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  background-color: #FAFAFA;
}

.message-bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.msg-user {
  background-color: #6BAAF7;
  margin-left: auto;
  border-bottom-right-radius: 12rpx;
}

.msg-user .message-text {
  color: #FFFFFF;
}

.msg-assistant {
  background-color: #FFFFFF;
  margin-right: auto;
  border-bottom-left-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.msg-assistant .message-text {
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

.retry-btn {
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background-color: #6BAAF7;
  border-radius: 16rpx;
  text-align: center;
}

.retry-text {
  color: #FFFFFF;
  font-size: 24rpx;
}

/* === Input Area === */
.panel-input {
  display: flex;
  align-items: flex-end;
  padding: 20rpx 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
  flex-shrink: 0;
}

.input-textarea {
  flex: 1;
  min-height: 64rpx;
  max-height: 200rpx;
  padding: 12rpx 16rpx;
  background-color: #F5F5F5;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
}

.send-btn {
  margin-left: 16rpx;
  padding: 12rpx 28rpx;
  background-color: #6BAAF7;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.send-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
}
