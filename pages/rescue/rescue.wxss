.container {
  background-color: transparent;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.header {
  min-height: 100vh;
  background-color: #FFFFFF;
}

.main-content {
  padding: 40rpx 32rpx;
}

.rescue-card {
  background-color: #FFF2F2;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 82, 82, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255, 82, 82, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.rescue-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FF5252;
}

.rescue-number {
  font-size: 60rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.rescue-desc {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.btn-call {
  background-color: #FF5252;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  width: 100% !important;
  box-shadow: 0 6rpx 20rpx rgba(255, 82, 82, 0.3);
}

.btn-call:active {
  opacity: 0.9;
  transform: scale(0.98);
}
