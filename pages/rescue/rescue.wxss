/* pages/rescue/rescue.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.main-content {
  padding: 32rpx;
}

.rescue-card {
  background-color: #FFF2F2;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.rescue-text {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.btn-call {
  background-color: #FF5252;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
  width: 100%;
}

