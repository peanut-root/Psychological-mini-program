/* pages/my-page/my-page.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.main-content {
  padding: 32rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #4096FF;
  border-bottom: 1rpx solid #E0E0E0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item text:last-child {
  color: #999999;
  font-size: 28rpx;
}

