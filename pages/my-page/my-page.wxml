<!--pages/my-page/my-page.wxml-->
<view class="my-page-wrapper">
  <!-- 用户信息头部 - 通栏设计 -->
  <view class="user-section">
    <block wx:if="{{!hasUserInfo}}">
      <view class="login-prompt" bindtap="getUserProfile">
        <view class="avatar-placeholder">?</view>
        <view class="login-text">
          <text class="user-name">点击登录微信</text>
          <text class="user-desc">登录后开启更多心理功能</text>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="user-status">心屿居民</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 功能列表 - 通栏设计 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="navigateToUserInfo">
      <view class="menu-left">
        <text class="menu-icon">👤</text>
        <text class="menu-text">个人信息</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="navigateToDiary">
      <view class="menu-left">
        <text class="menu-icon">📓</text>
        <text class="menu-text">我的日志</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="navigateToTreehole">
      <view class="menu-left">
        <text class="menu-icon">🕳️</text>
        <text class="menu-text">我的树洞</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group margin-top">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>