/* pages/diary/diary.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.main-content {
  padding: 32rpx;
}

.title-input {
  width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #E0E0E0;
  margin-bottom: 24rpx;
}

.content-textarea {
  width: 100%;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #E0E0E0;
  min-height: 400rpx;
  margin-bottom: 32rpx;
}

.btn-save {
  background-color: #4096FF;
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  border: none;
  width: 100%;
}

