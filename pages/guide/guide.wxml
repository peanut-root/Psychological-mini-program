<!--pages/guide/guide.wxml-->
<view class="container">
  <!-- 三个指南卡片 -->
  <view class="guide-list">
    <view class="guide-card" bindtap="navigateToHospital">
      <view class="card-icon">🏥</view>
      <text class="card-title">医院推荐</text>
      <text class="card-desc">优质心理医疗机构推荐</text>
      <text class="arrow">›</text>
    </view>

    <view class="guide-card" bindtap="navigateToEndorsement">
      <view class="card-icon">📋</view>
      <text class="card-title">就诊背书</text>
      <text class="card-desc">就诊前准备与材料清单</text>
      <text class="arrow">›</text>
    </view>

    <view class="guide-card" bindtap="navigateToProcess">
      <view class="card-icon">🔄</view>
      <text class="card-title">就诊流程介绍</text>
      <text class="card-desc">从挂号到诊断的完整流程</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
