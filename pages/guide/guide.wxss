/* pages/guide/guide.wxss */
.container {
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* 指南列表 */
.guide-list {
  padding: 24rpx;
}

.guide-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 28rpx;
  color: #999999;
  display: block;
}

.arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #CCCCCC;
}
