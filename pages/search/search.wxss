/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-top: 140rpx;
}

/* 顶部搜索栏 */
.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.search-box {
  flex: 1;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 80rpx;
}

.search-icon {
  font-size: 36rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

.clear-btn {
  font-size: 36rpx;
  color: #CCCCCC;
  padding: 0 8rpx;
}

.cancel-btn {
  font-size: 30rpx;
  color: #4096FF;
  padding: 0 8rpx;
  white-space: nowrap;
}

/* 默认内容区 */
.default-content {
  padding: 32rpx 24rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.clear-history {
  font-size: 26rpx;
  color: #999999;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tag-item.recommend {
  background-color: #FFF7E6;
}

.tag-icon {
  font-size: 24rpx;
}

.tag-text {
  font-size: 28rpx;
  color: #333333;
}

/* 搜索结果 */
.results {
  padding: 24rpx;
}

.result-item {
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  width: calc(100% - 110rpx); /* 动态适配，预留取消按钮空间 */
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #999999;
  display: block;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  padding-top: 200rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #CCCCCC;
}

