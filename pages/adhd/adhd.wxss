/* pages/adhd/adhd.wxss */
.container {
  background-color: transparent;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.header {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}
.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: bold;
}
.main-content {
  padding: 32rpx;
}
.content-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.content-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}
