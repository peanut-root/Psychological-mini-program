/* pages/literature/literature.wxss */
.container {
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* 搜索区域 */
.search-section {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 8rpx 24rpx;
  z-index: 99;
}

.search-box {
  background-color: #F5F5F5;
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #999999;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999999;
}

/* 分类标签区域 */
.category-section {
  position: fixed;
  top: 90rpx;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 12rpx 0;
  z-index: 98;
  border-bottom: 1rpx solid #F0F0F0;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  white-space: nowrap;
}

.category-item.active {
  background-color: #4096FF;
  color: #FFFFFF;
}

/* 文献列表 */
.literature-list {
  margin-top: 15rpx;
  padding: 16rpx 24rpx 32rpx;
}

.literature-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tag {
  background-color: #E6F7FF;
  color: #1890FF;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.date {
  font-size: 24rpx;
  color: #CCCCCC;
}

.literature-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.literature-summary {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.item-footer {
  display: flex;
  gap: 32rpx;
  font-size: 24rpx;
  color: #999999;
}

.view-count,
.like-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

