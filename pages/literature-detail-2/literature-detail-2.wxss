/* pages/literature-detail-2/literature-detail-2.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}
.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: bold;
}
.main-content {
  padding: 32rpx;
}
.detail-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}
.detail-source {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 32rpx;
}
.detail-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
}

