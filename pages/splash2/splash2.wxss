/* pages/splash2/splash2.wxss */
@import "../../styles/theme.wxss";

.container {
    width: 100vw;
    height: 100vh;
    background-color: #FFF6D8;
    position: relative;
    overflow: hidden;
  }
  
  .title-area {
    position: absolute;
    top: 100rpx;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 10;
    padding: 0 32rpx;
  }
  
  .main-title {
    font-size: 64rpx;
    font-weight: bold;
    color: #333333;
    display: block;
    margin-bottom: 24rpx;
  }
  
  .sub-title {
    font-size: 28rpx;
    color: #666666;
    display: block;
    margin-bottom: 40rpx;
  }
  
  .progress-bar {
    width: 400rpx;
    height: 8rpx;
    background-color: rgba(255, 255, 255, 0.5);
    border-radius: 4rpx;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }
  
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #4096FF, #FF7A45);
    border-radius: 4rpx;
    transition: width 0.3s ease;
  }
  
  .progress-text {
    position: absolute;
    top: 20rpx;
    left: 50%;
    transform: translateX(-50%);
    font-size: 24rpx;
    color: #4096FF;
    font-weight: bold;
  }
  
  .bubbles-container {
    width: 100%;
    height: 100%;
    position: relative;
    padding-top: 300rpx;
  }
  
  .bubble {
    position: absolute;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .bubble-number {
    /* 【核心修改1】移除固定font-size: 48rpx，改为由WXML动态绑定控制 */
    font-weight: bold;
    color: #ffffff;
    text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
    /* 【核心修改2】新增文字防溢出样式，适配动态文字和泡泡大小 */
    white-space: nowrap; /* 禁止文字换行，保持单行显示 */
    word-break: keep-all; /* 禁止汉字/英文单词拆分 */
    max-width: calc(100% - 40rpx); /* 预留40rpx内边距，防止文字紧贴泡泡边缘溢出 */
    line-height: 1; /* 优化文字垂直对齐，避免行高过大导致偏移 */
    text-align: center; /* 确保文字水平居中，适配短文字和长文字 */
  }
  
  .bubble.selected {
    opacity: 1;
    box-shadow: 0 0 30rpx rgba(64, 150, 255, 0.6);
    border: 4rpx solid #4096FF;
  }
  
  .bubble.popped {
    animation: pop 0.5s ease-out forwards;
    pointer-events: none;
    opacity: 0;
  }
  
  @keyframes pop {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.3);
      opacity: 0.4;
    }
    100% {
      transform: scale(0);
      opacity: 0;
    }
  }
  
  /* 戳破特效 - 使用CSS动画 */
  .pop-effect {
    position: absolute;
    width: 120rpx;
    height: 120rpx;
    transform: translate(-50%, -50%);
    z-index: 9999;
    pointer-events: none;
  }
  
  .pop-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 8rpx solid rgba(64, 150, 255, 0.8);
    border-radius: 50%;
    animation: popRing 0.6s ease-out;
  }
  
  .pop-particles {
    position: absolute;
    width: 100%;
    height: 100%;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  
  .particle {
    position: absolute;
    width: 16rpx;
    height: 16rpx;
    background: radial-gradient(circle, rgba(255, 107, 157, 0.9), rgba(255, 107, 157, 0.3));
    border-radius: 50%;
    left: 50%;
    top: 50%;
    margin-left: -8rpx;
    margin-top: -8rpx;
  }
  
  .particle-0 {
    animation: popParticle0 0.6s ease-out;
  }
  
  .particle-1 {
    animation: popParticle1 0.6s ease-out;
  }
  
  .particle-2 {
    animation: popParticle2 0.6s ease-out;
  }
  
  .particle-3 {
    animation: popParticle3 0.6s ease-out;
  }
  
  .particle-4 {
    animation: popParticle4 0.6s ease-out;
  }
  
  .particle-5 {
    animation: popParticle5 0.6s ease-out;
  }
  
  .particle-6 {
    animation: popParticle6 0.6s ease-out;
  }
  
  .particle-7 {
    animation: popParticle7 0.6s ease-out;
  }
  
  @keyframes popRing {
    0% {
      transform: scale(0);
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }
  
  /* 8个方向的粒子动画 */
  @keyframes popParticle0 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(0, -80rpx) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle1 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(56rpx, -56rpx) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle2 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(80rpx, 0) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle3 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(56rpx, 56rpx) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle4 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(0, 80rpx) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle5 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(-56rpx, 56rpx) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle6 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(-80rpx, 0) scale(0);
      opacity: 0;
    }
  }
  
  @keyframes popParticle7 {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(-56rpx, -56rpx) scale(0);
      opacity: 0;
    }
  }

.skip-button {
  position: absolute;
  right: 32rpx;
  bottom: 40rpx;
  padding: 14rpx 28rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.12);
  color: #333;
  font-size: 26rpx;
  z-index: 20;
}

