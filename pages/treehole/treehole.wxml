<!--pages/treehole/treehole.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">← 返回</view>
    <text class="header-title">心情树洞</text>
  </view>
  <view class="main-content">
    <textarea class="treehole-input" placeholder="说说你的心情..." value="{{content}}" bindinput="onInput" maxlength="500"></textarea>
    <button class="btn-publish" bindtap="publish">匿名发布</button>
  </view>
</view>

