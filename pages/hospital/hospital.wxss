.container {
  background-color: transparent;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.header {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  box-sizing: border-box;
  background-color: #FFFFFF;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 60rpx;
  position: relative;
}

.title-section {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F1F1F;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #5A5A5A;
}

.region-selector {
  background: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #EEEEEE;
}

.current-region {
  font-size: 28rpx;
  color: #1F1F1F;
  margin-right: 8rpx;
  font-weight: 500;
}

.arrow-down {
  font-size: 20rpx;
  color: #999999;
}

.hospital-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.hospital-card {
  padding: 40rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.tag-blue {
  background: #E6F4FF;
  color: #1890FF;
}

.tag-purple {
  background: #F9F0FF;
  color: #722ED1;
}

.dept-info {
  font-size: 22rpx;
  color: #999999;
}

.hospital-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F1F1F;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.hospital-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 24rpx;
}

.location-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #1890FF;
}

.location-btn .icon {
  margin-right: 8rpx;
}

.footer-tips {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
}
