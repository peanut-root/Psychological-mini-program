/* pages/literature-detail-1/literature-detail-1.wxss */
.container {
  background-color: transparent;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.header {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}
.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: bold;
}
.main-content {
  padding: 32rpx;
}
.detail-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.4;
}
.detail-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.detail-author {
  font-size: 28rpx;
  color: #666666;
}
.detail-date {
  font-size: 28rpx;
  color: #999999;
}
.detail-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
}

/* 互动操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 0;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.action-icon.liked {
  color: #ff4757;
}
.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 评论输入框 */
.comment-input-container {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.comment-input-box {
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  overflow: hidden;
}
.comment-textarea {
  width: calc(100% - 48rpx);
  min-height: 120rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}
.comment-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  background-color: #f9f9f9;
}
.cancel-btn, .submit-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}
.cancel-btn {
  color: #666;
  margin-right: 16rpx;
}
.submit-btn {
  color: #fff;
  background-color: #4096FF;
}

/* 评论区域 */
.comments-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.comments-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}
.comment-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.comment-item:last-child {
  border-bottom: none;
}
.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.comment-user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}
.comment-user-info {
  flex: 1;
}
.comment-user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}
.comment-time {
  font-size: 22rpx;
  color: #999999;
  display: block;
}
.comment-like {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.comment-like-icon {
  font-size: 28rpx;
}
.comment-like-count {
  font-size: 24rpx;
  color: #999999;
}
.comment-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
  margin-top: 8rpx;
}

