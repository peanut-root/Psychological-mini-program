<!--pages/literature-detail-1/literature-detail-1.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">← 返回</view>
    <text class="header-title">文献详情</text>
  </view>
  
  <view class="main-content">
    <view class="detail-card">
      <text class="detail-title">{{article.title}}</text>
      <view class="detail-meta">
        <text class="detail-author">{{article.author}}</text>
        <text class="detail-date">{{article.date}}</text>
      </view>
      <text class="detail-content">{{article.content}}</text>
    </view>
    
    <!-- 点赞、评论、分享区域 -->
    <view class="action-bar">
      <view class="action-item" bindtap="onLike">
        <text class="{{article.liked ? 'action-icon liked' : 'action-icon'}}">❤</text>
        <text class="action-text">{{article.likes}}</text>
      </view>
      <view class="action-item" bindtap="showCommentInput">
        <text class="action-icon">💬</text>
        <text class="action-text">评论</text>
      </view>
      <view class="action-item" bindtap="onShare">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </view>
    </view>
    
    <!-- 评论输入框 -->
    <view class="comment-input-container" wx:if="{{showCommentInput}}">
      <view class="comment-input-box">
        <textarea class="comment-textarea" value="{{newComment}}" bindinput="onCommentInput" placeholder="写下你的评论..." maxlength="500"></textarea>
        <view class="comment-actions">
          <text class="cancel-btn" bindtap="hideCommentInput">取消</text>
          <text class="submit-btn" bindtap="submitComment">发送</text>
        </view>
      </view>
    </view>
    
    <!-- 评论列表 -->
    <view class="comments-section">
      <text class="comments-title">评论 ({{article.comments.length}})</text>
      <view class="comment-item" wx:for="{{article.comments}}" wx:key="id">
        <view class="comment-header">
          <view class="comment-user-avatar">👤</view>
          <view class="comment-user-info">
            <text class="comment-user-name">{{item.user}}</text>
            <text class="comment-time">{{item.time}}</text>
          </view>
          <view class="comment-like" bindtap="onCommentLike" data-index="{{index}}">
            <text class="comment-like-icon">👍</text>
            <text class="comment-like-count">{{item.likes}}</text>
          </view>
        </view>
        <view class="comment-content">{{item.content}}</view>
      </view>
    </view>
  </view>
</view>

