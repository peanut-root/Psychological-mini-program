/* pages/user-info/user-info.wxss */
.user-info-wrapper {
  min-height: 100vh;
  background-color: #F8F9FA;
  width: 100vw;
  overflow-x: hidden;
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  background-color: #FFFFFF;
  min-height: 100vh;
}

.avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  background-color: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.avatar-icon {
  font-size: 90rpx;
  color: #CCCCCC;
}

.welcome-text {
  font-size: 42rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.login-hint {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 80rpx;
}

.login-btn {
  width: 80% !important;
  height: 96rpx;
  background-color: #4096FF;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

/* 已登录状态 */
.profile-header {
  background-color: #ffffff;
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-right: 32rpx;
  border: 4rpx solid #F5F5F5;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999999;
}

/* 设置列表组 */
.settings-group {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.group-title {
  font-size: 26rpx;
  color: #999999;
  padding: 24rpx 40rpx 16rpx;
  background-color: #F8F9FA;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  flex-direction: column;
}

.item-label {
  font-size: 30rpx;
  color: #333333;
}

.item-desc {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 28rpx;
  color: #999999;
  margin-right: 12rpx;
}

.avatar-small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  margin-right: 12rpx;
}

.arrow {
  font-size: 40rpx;
  color: #CCCCCC;
}

/* 退出按钮 */
.logout-box {
  padding: 60rpx 40rpx;
}

.logout-btn {
  width: 100% !important;
  height: 96rpx;
  background-color: #ffffff;
  color: #FF4D4F;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 1rpx solid #FF4D4F;
}
