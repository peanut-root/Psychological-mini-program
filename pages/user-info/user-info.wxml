<!--pages/user-info/user-info.wxml-->
<view class="user-info-wrapper">
  <!-- 未登录状态 -->
  <view class="not-logged-in" wx:if="{{!isLoggedIn}}">
    <view class="avatar-placeholder">
      <text class="avatar-icon">👤</text>
    </view>
    <text class="welcome-text">欢迎来到心屿</text>
    <text class="login-hint">登录后查看完整信息</text>
    <button class="login-btn" bindtap="onLogin">微信快捷登录</button>
  </view>

  <!-- 已登录状态 -->
  <view class="logged-in" wx:else>
    <!-- 用户信息头部 -->
    <view class="profile-header">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" bindtap="changeAvatar"></image>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-id">ID: {{userInfo.userId}}</text>
      </view>
    </view>

    <!-- 资料设置列表 - 全宽设计 -->
    <view class="settings-group">
      <view class="group-title">个人资料</view>
      <view class="setting-item" bindtap="editNickname">
        <text class="item-label">昵称</text>
        <view class="item-right">
          <text class="item-value">{{userInfo.nickName}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="setting-item" bindtap="changeAvatar">
        <text class="item-label">头像</text>
        <view class="item-right">
          <image class="avatar-small" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="setting-item">
        <text class="item-label">性别</text>
        <view class="item-right">
          <text class="item-value">{{userInfo.gender}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="settings-group">
      <view class="group-title">就诊辅助</view>
      <view class="setting-item" bindtap="navigateToEndorsementResult">
        <view class="item-left">
          <text class="item-label">我的就诊背书</text>
          <text class="item-desc">查看已生成的问诊记录结果</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="settings-group">
      <view class="group-title">账号设置</view>
      <view class="setting-item">
        <text class="item-label">隐私设置</text>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="setting-item">
        <text class="item-label">清除缓存</text>
        <view class="item-right">
          <text class="item-value">12.5 MB</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-box">
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
    
    <!-- 临时按钮：重置引导状态（仅用于测试） -->
    <view class="logout-box">
      <button class="logout-btn" bindtap="resetOnboarding">重置引导状态（测试用）</button>
    </view>
  </view>
</view>