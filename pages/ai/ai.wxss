/* pages/ai/ai.wxss */
@import "../../styles/theme.wxss";

.container {
  min-height: 100vh;
  background-color: #FFF6D8;
}

.header {
  background-color: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn {
  color: #4096FF;
  margin-right: 24rpx;
  font-size: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.chat-container {
  height: calc(100vh - 88rpx);
  display: flex;
  flex-direction: column;
}

.messages {
  flex: 1;
  padding: 32rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.message {
  display: flex;
  margin-bottom: 16rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.message-content {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message.user .message-content {
  background-color: #4096FF;
  color: white;
}

.message.assistant .message-content {
  background-color: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.input-area {
  display: flex;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e0e0e0;
}

.input {
  flex: 1;
  border: 1rpx solid #e0e0e0;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.send-btn {
  background-color: #4096FF;
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.send-btn[disabled] {
  background-color: #cccccc;
}

.debug-bar {
  padding: 16rpx 32rpx;
  color: #999999;
  font-size: 24rpx;
  background-color: #fff8dc;
  border-bottom: 1rpx solid #f0e7c3;
}


