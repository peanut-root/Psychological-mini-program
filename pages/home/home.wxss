/* pages/home/home.wxss */
@import "../../styles/theme.wxss";

.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-bottom: 200rpx; /* 预留底部bar空间 */
}

.main-content {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.top-cards {
  display: flex;
  gap: 20rpx;
}

.card-rescue {
  background-color: #FFF2F2;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 240rpx;
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  align-items: stretch;
  text-align: center;
}

.card-guide {
  background-color: #E6F4FF;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 240rpx;
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  align-items: stretch;
  text-align: center;
}

.card-hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
  width: 100%;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.card-title-small {
  font-size: 28rpx;
  font-weight: bold;
  margin: 16rpx 0;
}

.star-icon-small {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #FFD700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.star-icon-medium {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #FFD700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 24rpx;
}

.card-text {
  font-size: 28rpx;
  color: #333333;
  margin: 24rpx 0;
  line-height: 1.6;
  white-space: pre-line;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background-color: #4096FF;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  border: none;
  margin-top: 16rpx;
  width: 100% !important;
  box-sizing: border-box;
}

.btn-accent {
  background-color: #FF7A45;
  color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  border: none;
  margin-top: 16rpx;
  width: 100% !important;
  box-sizing: border-box;
}

.science-vertical {
  display: grid;
  gap: 24rpx;
}

.science-block {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(64, 150, 255, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.science-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.science-key,
.science-disease {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.science-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.science-row {
  background: #F5F9FF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #2f4f73;
  border: 2rpx solid rgba(64, 150, 255, 0.12);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  box-shadow: 0 -6rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 20rpx;
  z-index: 80;
}

.bar-btn {
  flex: 1;
  margin: 0 10rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #F2F6FF;
  color: #2f4f73;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.bar-btn-primary {
  background: #4096FF;
  color: #fff;
}

.toast {
  position: fixed;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 40rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  z-index: 9999;
}

.toast.show {
  opacity: 1;
}

