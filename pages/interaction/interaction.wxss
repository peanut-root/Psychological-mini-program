/* pages/interaction/interaction.wxss */
.container {
  background-color: transparent;
  position: relative;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.header {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.main-content {
  padding: 32rpx;
}

.interaction-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.interaction-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #333333;
}

.interaction-item text:last-child {
  color: #999999;
  font-size: 28rpx;
}

